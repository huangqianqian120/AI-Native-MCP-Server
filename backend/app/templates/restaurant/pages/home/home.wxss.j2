.home { padding: 80rpx 40rpx; text-align: center; }
.home__hero { margin-bottom: 80rpx; }
.home__title { font-size: 48rpx; font-weight: 700; color: #333; margin-bottom: 16rpx; }
.home__subtitle { font-size: 28rpx; color: #999; }
.home__tip { font-size: 28rpx; color: #666; margin-bottom: 40rpx; padding: 20rpx; background: #fff; border-radius: 12rpx; }
.home__examples { display: flex; flex-direction: column; gap: 16rpx; }
.home__example { padding: 20rpx; background: #fff; border-radius: 12rpx; font-size: 26rpx; color: #999; }
