.order-list { background: #fff; border-radius: 16rpx; margin: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.order-list__title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.order-row { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.order-row__top { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.order-row__store { font-size: 28rpx; color: #333; }
.order-row__price { font-size: 28rpx; color: #ff6b35; font-weight: 500; }
.order-row__bottom { display: flex; justify-content: space-between; }
.order-row__time { font-size: 22rpx; color: #999; }
.order-row__status { font-size: 22rpx; color: #666; }
.order-list__empty { text-align: center; font-size: 26rpx; color: #999; padding: 40rpx; }
