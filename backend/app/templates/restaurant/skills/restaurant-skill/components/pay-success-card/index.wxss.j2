.pay-card { background: #fff; border-radius: 16rpx; margin: 20rpx; padding: 40rpx; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.pay-card__icon { font-size: 80rpx; margin-bottom: 16rpx; }
.pay-card__title { font-size: 36rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.pay-card__amount { font-size: 48rpx; font-weight: 700; color: #07c160; margin-bottom: 12rpx; }
.pay-card__meta { font-size: 26rpx; color: #999; margin-bottom: 24rpx; }
.pay-card__track { background: #f5f5f5; color: #333; border-radius: 12rpx; font-size: 28rpx; }
