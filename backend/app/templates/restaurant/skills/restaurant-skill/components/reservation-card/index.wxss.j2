.reserve-card { background: #fff; border-radius: 16rpx; margin: 20rpx; padding: 32rpx; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.reserve-card__header { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.reserve-card__queue-label { font-size: 22rpx; color: #999; }
.reserve-card__queue-num { font-size: 64rpx; font-weight: 700; color: #ff6b35; margin: 8rpx 0; }
.reserve-card__wait { font-size: 26rpx; color: #666; }
.reserve-card__booking { font-size: 28rpx; color: #07c160; }
