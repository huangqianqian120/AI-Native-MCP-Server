.track-card { background: #fff; border-radius: 16rpx; margin: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.track-card__title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.track-step { display: flex; align-items: flex-start; margin-bottom: 16rpx; }
.track-step__dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #e8e8e8; margin-top: 8rpx; margin-right: 16rpx; }
.track-step--done .track-step__dot { background: #07c160; }
.track-step__info { flex: 1; }
.track-step__name { font-size: 28rpx; color: #333; }
.track-step__time { font-size: 22rpx; color: #999; margin-left: 12rpx; }
.track-card__eta { text-align: center; font-size: 26rpx; color: #07c160; margin-top: 16rpx; }
