<view class="coupon-list">
  <view class="coupon-list__title">优惠券</view>
  <view wx:for="{{coupons}}" wx:key="couponId" class="coupon-item">
    <view class="coupon-item__info">
      <view class="coupon-item__title">{{item.title}}</view>
      <view class="coupon-item__desc">{{item.description}}</view>
      <view class="coupon-item__threshold" wx:if="{{item.threshold}}">{{item.threshold}}</view>
    </view>
    <button class="coupon-item__claim" data-coupon="{{item}}" bind:tap="onClaim">领取</button>
  </view>
  <view wx:if="{{coupons.length === 0}}" class="coupon-list__empty">暂无可用优惠券</view>
</view>
