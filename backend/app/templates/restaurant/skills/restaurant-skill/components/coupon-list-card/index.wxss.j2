.coupon-list { background: #fff; border-radius: 16rpx; margin: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.coupon-list__title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.coupon-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.coupon-item__info { flex: 1; }
.coupon-item__title { font-size: 28rpx; font-weight: 500; color: #333; }
.coupon-item__desc { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.coupon-item__threshold { font-size: 22rpx; color: #ff6b35; margin-top: 4rpx; }
.coupon-item__claim { background: #ff6b35; color: #fff; border-radius: 8rpx; font-size: 24rpx; padding: 8rpx 24rpx; height: auto; line-height: 2; }
.coupon-list__empty { text-align: center; font-size: 26rpx; color: #999; padding: 40rpx; }
