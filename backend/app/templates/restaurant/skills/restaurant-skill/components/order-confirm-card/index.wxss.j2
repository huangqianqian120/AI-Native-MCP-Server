.order-card { background: #fff; border-radius: 16rpx; margin: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.order-card__header { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.order-item { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; color: #333; border-bottom: 1rpx solid #f5f5f5; }
.order-card__total { display: flex; justify-content: space-between; padding: 16rpx 0; font-size: 30rpx; font-weight: 600; }
.order-card__price { color: #ff6b35; }
.order-card__address { background: #fff8e1; padding: 16rpx; border-radius: 8rpx; font-size: 26rpx; color: #f57c00; text-align: center; margin-bottom: 16rpx; }
.order-card__pay { background: #07c160; color: #fff; border-radius: 12rpx; font-size: 30rpx; padding: 20rpx; }
.order-card__status { font-size: 22rpx; color: #999; margin-top: 12rpx; text-align: center; }
