Component({
  data: { order: null, items: [], totalPrice: 0, orderId: '', needAddress: false, status: '' },
  lifetimes: {
    created() {
      this._modelCtx = wx.modelContext.getContext(this)
      const { NotificationType } = wx.modelContext
      this._modelCtx.on(NotificationType.Result, (data) => {
        const result = (data && data.result) || {}
        const sc = result.structuredContent || {}
        const meta = result._meta || {}
        this.setData({
          order: meta.order || sc, items: sc.items || meta.items || [],
          totalPrice: sc.totalPrice || 0, orderId: sc.orderId || '',
          status: sc.status || '', needAddress: sc.needAddress
        })
      })
    }
  },
  methods: {
    onPay() {
      if (!this.data.orderId) return
      this._modelCtx.sendFollowUpMessage({
        content: [
          { type: 'text', text: '确认支付' },
          { type: 'api/call', data: { name: 'payOrder', arguments: { orderId: this.data.orderId } } }
        ]
      })
    },
    onAddress() {
      const ctx = wx.modelContext.getViewContext(this)
      ctx.openDetailPage({ url: '/packageDetail/pages/address-editor' })
    }
  }
})
