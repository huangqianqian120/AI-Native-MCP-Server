.store-list { padding: 20rpx; }
.store-list__title { font-size: 36rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.store-list__subtitle { font-size: 28rpx; color: #999; margin-bottom: 24rpx; }
.store-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.store-card__name { font-size: 32rpx; font-weight: 500; color: #333; margin-bottom: 12rpx; }
.store-card__meta { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.store-card__distance { font-size: 24rpx; color: #999; }
.store-card__status { font-size: 24rpx; color: #999; }
.status--open { color: #07c160; }
.status--closed { color: #ff4d4f; }
.store-card__address { font-size: 26rpx; color: #666; }
