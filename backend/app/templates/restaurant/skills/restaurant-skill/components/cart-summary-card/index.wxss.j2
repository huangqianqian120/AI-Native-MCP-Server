.cart-card { background: #fff; border-radius: 16rpx; margin: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.cart-card__header { display: flex; justify-content: space-between; align-items: center; }
.cart-card__title { font-size: 30rpx; font-weight: 600; color: #333; }
.cart-card__count { font-size: 28rpx; color: #ff6b35; font-weight: 500; }
.cart-card__body { margin-top: 16rpx; }
.cart-item { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.cart-item__name { font-size: 26rpx; color: #333; }
.cart-item__price { font-size: 26rpx; color: #ff6b35; }
.cart-card__checkout { margin-top: 20rpx; background: #ff6b35; color: #fff; border-radius: 12rpx; font-size: 28rpx; }
