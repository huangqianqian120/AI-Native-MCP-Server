.dish-detail { background: #fff; border-radius: 16rpx; overflow: hidden; margin: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.dish-detail__img { width: 100%; height: 360rpx; }
.dish-detail__body { padding: 24rpx; }
.dish-detail__name { font-size: 36rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.dish-detail__desc { font-size: 26rpx; color: #999; margin-bottom: 12rpx; }
.dish-detail__price { font-size: 36rpx; font-weight: 700; color: #ff6b35; margin-bottom: 24rpx; }
.spec-group { margin-bottom: 20rpx; }
.spec-group__label { font-size: 28rpx; font-weight: 500; color: #666; margin-bottom: 12rpx; }
.spec-group__options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.spec-option { padding: 12rpx 24rpx; border: 2rpx solid #e8e8e8; border-radius: 8rpx; font-size: 26rpx; color: #333; }
.spec-option--selected { border-color: #333; background: #333; color: #fff; }
.dish-detail__actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.btn { flex: 1; padding: 20rpx; text-align: center; border-radius: 12rpx; font-size: 28rpx; }
.btn--primary { background: #ff6b35; color: #fff; }
.btn--secondary { background: #f5f5f5; color: #333; }
.dish-detail--empty { padding: 40rpx; text-align: center; }
.dish-detail__empty-text { font-size: 28rpx; color: #999; }
