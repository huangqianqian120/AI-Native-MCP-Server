.sku-page { padding: 20rpx; }
.sku-page__header { display: flex; align-items: center; padding: 24rpx; background: #fff; border-radius: 16rpx; margin-bottom: 20rpx; }
.sku-page__img { width: 160rpx; height: 160rpx; border-radius: 12rpx; margin-right: 20rpx; }
.sku-page__name { font-size: 32rpx; font-weight: 600; color: #333; flex: 1; }
.sku-page__price { font-size: 36rpx; font-weight: 700; color: #ff6b35; }
.sku-group { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; }
.sku-group__label { font-size: 28rpx; font-weight: 500; color: #666; margin-bottom: 16rpx; }
.sku-group__options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.sku-option { padding: 16rpx 32rpx; border: 2rpx solid #e8e8e8; border-radius: 12rpx; font-size: 26rpx; color: #333; }
.sku-option--selected { border-color: #333; background: #333; color: #fff; }
.sku-page__confirm { width: 100%; background: #ff6b35; color: #fff; border-radius: 12rpx; padding: 24rpx; font-size: 32rpx; margin-top: 32rpx; }
