<view class="addr-page">
  <view class="addr-field">
    <text class="addr-field__label">联系人</text>
    <input class="addr-field__input" placeholder="请输入姓名" value="{{name}}" data-field="name" bindinput="onInput"/>
  </view>
  <view class="addr-field">
    <text class="addr-field__label">手机号</text>
    <input class="addr-field__input" placeholder="请输入手机号" type="number" maxlength="11" value="{{phone}}" data-field="phone" bindinput="onInput"/>
  </view>
  <view class="addr-field">
    <text class="addr-field__label">详细地址</text>
    <input class="addr-field__input" placeholder="请输入详细地址" value="{{detail}}" data-field="detail" bindinput="onInput"/>
  </view>
  <button class="addr-page__save" bind:tap="onSave">保存地址</button>
</view>
